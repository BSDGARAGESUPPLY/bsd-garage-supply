{
  "name": "bsd-garage-supply",
  "version": "1.0.0",
  "description": "BSD Garage Supply — garage door springs & hardware e-commerce platform",
  "main": "server/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "seed": "node server/seed.js",
    "client": "cd client && npm run dev",
    "build": "npm --prefix client install --include=dev && npm --prefix client run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.0",
    "stripe": "^14.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
