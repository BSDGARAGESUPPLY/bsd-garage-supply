# ── Core ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# In production set DATA_DIR to a persistent volume path (e.g. /data on Railway)
# DATA_DIR=/data

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Admin seed (created on first boot if missing) ─────────────
ADMIN_EMAIL=bsdgaragesupply@gmail.com
ADMIN_PASSWORD=change-me

# ── Email (SMTP) ──────────────────────────────────────────────
# Leave blank to log emails to the console instead of sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bsdgaragesupply@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=BSD Garage Supply <bsdgaragesupply@gmail.com>

# ── Stripe (add for live payments) ────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Public site URL (used in emails & links) ──────────────────
CLIENT_URL=http://localhost:5173

# ── Sales tax ─────────────────────────────────────────────────
# Percent applied to the order subtotal. Florida state is 6%; add your county
# surtax (e.g. 6.5 for 6% + 0.5%). Verify your exact rate with your accountant.
SALES_TAX_PERCENT=6.5
